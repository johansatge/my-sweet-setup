      "Bash(npm list)",
      "Bash(npm list *)",
      "Bash(rtk npm list)",
      "Bash(rtk npm list *)",

      "Bash(npm info)",
      "Bash(npm info *)",
      "Bash(rtk npm info)",
      "Bash(rtk npm info *)",

      "Bash(npm outdated)",
      "Bash(npm outdated *)",
      "Bash(rtk npm outdated)",
      "Bash(rtk npm outdated *)",

      "Bash(npm audit)",
      "Bash(npm audit *)",
      "Bash(rtk npm audit)",
      "Bash(rtk npm audit *)",

      "Bash(pnpm ls)",
      "Bash(pnpm ls *)",
      "Bash(rtk pnpm ls)",
      "Bash(rtk pnpm ls *)",

      "Bash(pnpm list)",
